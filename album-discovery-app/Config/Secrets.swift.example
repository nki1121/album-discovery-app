import Foundation

// 【テンプレートファイル】
//
// このファイルは Xcode のコンパイル対象外です(拡張子が .swift.example のため)。
// 使い方:
//   1. このファイルを同じディレクトリにコピーして名前を「Secrets.swift」に変える
//   2. Secrets.swift の中の YOUR_*_HERE を、Spotify Developer Dashboard で
//      取得した実際の Client ID / Client Secret に置き換える
//   3. Secrets.swift は .gitignore で除外されるためコミットされない
//
// Spotify Developer Dashboard:
//   https://developer.spotify.com/dashboard

enum Secrets {
    static let spotifyClientID: String = "YOUR_CLIENT_ID_HERE"
    static let spotifyClientSecret: String = "YOUR_CLIENT_SECRET_HERE"
}
