import Foundation

// 【テンプレートファイル】
//
// このファイルは Xcode のコンパイル対象外です(拡張子が .swift.example のため)。
// 使い方:
//   1. このファイルを同じディレクトリにコピーして名前を「Secrets.swift」に変える
//   2. Secrets.swift は .gitignore で除外されるためコミットされない
//   3. 秘密情報の実体は Xcode の Scheme の Environment Variables に登録する
//      - Xcode: Product → Scheme → Edit Scheme → Run → Arguments → Environment Variables
//      - 追加する変数:
//          SPOTIFY_CLIENT_ID     = (Spotify Developer Dashboard で取得した Client ID)
//          SPOTIFY_CLIENT_SECRET = (Spotify Developer Dashboard で取得した Client Secret)
//
// Spotify Developer Dashboard:
//   https://developer.spotify.com/dashboard

enum Secrets {
    static var spotifyClientID: String {
        ProcessInfo.processInfo.environment["SPOTIFY_CLIENT_ID"] ?? ""
    }

    static var spotifyClientSecret: String {
        ProcessInfo.processInfo.environment["SPOTIFY_CLIENT_SECRET"] ?? ""
    }
}
